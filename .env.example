# Telegram API для сбора данных
TG_API_ID=your_api_id
TG_API_HASH=your_api_hash
TG_SESSION=oracul
TG_PHONE=+79990000000

# OpenRouter API для анализа
OPENROUTER_API_KEY=sk-or-v1-your_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
DEFAULT_MODEL=nvidia/nemotron-3-nano-30b-a3b:free
BACKUP_MODEL=arcee-ai/trinity-mini:free
THIRD_MODEL=openai/gpt-oss-120b:free
FOURTH_MODEL=openai/gpt-oss-20b:free
MAX_TOKENS=4000
TEMPERATURE=1

# GROQ API (для голосового анализа)
GROQ_API_KEY=gsk_your_key_here
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Настройки анализа
ANALYSIS_LANGUAGE=ru
ENABLE_PHOTO_ANALYSIS=true
ENABLE_BIO_ANALYSIS=true
ENABLE_PROFILE_ANALYSIS=true
MAX_MESSAGES_TO_ANALYZE=500
DAYS_BACK_TO_ANALYZE=30

# Целевой пользователь для анализа
TARGET_USER_ID=
TARGET_USERNAME=

# База данных
DATABASE_URL=sqlite:///./tg_analysis.db

# Безопасность
SECRET_KEY=your-secret-key-here
DEBUG=false

# Настройки сбора данных
COLLECT_PRIVATE_CHATS=true
COLLECT_GROUP_CHATS=false
COLLECT_CHANNELS=false
COLLECT_MEDIA_DESCRIPTIONS=true
COLLECT_REACTIONS=true
COLLECT_FORWARDS=true

# Лимиты и производительность
API_RATE_LIMIT=30
CONCURRENT_REQUESTS=3
RETRY_ATTEMPTS=3
TIMEOUT_SECONDS=30

# Telegram Bot
BOT_TOKEN=your_bot_token_here
BACKEND_API_URL=http://localhost:8000
ADMIN_IDS=your_telegram_id

# Email для автоматических откликов
EMAIL_PASSWORD=

# === Настройки сессий пользователей ===
# Время жизни сессии по умолчанию (в минутах)
DEFAULT_SESSION_TTL_MINUTES=60

# Доступные варианты TTL через запятую (минуты)
SESSION_TTL_OPTIONS_MINUTES=15,60,180,720,1440

# Режим сессии по умолчанию: persistent (TTL) или temporary (одноразовая)
DEFAULT_SESSION_MODE=persistent

# URL для Web App управления сессиями (опционально)
# SESSION_WEB_APP_URL=https://your-domain.com:8088

# ID пользователя для тестового приглашения (опционально)
# TEST_INVITE_USER_ID=123456789
